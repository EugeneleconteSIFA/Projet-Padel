# =============================================================================
# .env.example — copier en .env.local et remplir.
# Le fichier .env.local n'est jamais commité (cf. .gitignore).
# =============================================================================

# --- Base de données ---------------------------------------------------------
# Avec Neon (recommandé) :
#   DATABASE_URL = pooler PgBouncer, utilisé par Next.js au runtime
#   DIRECT_URL   = même URL SANS le suffixe "-pooler" dans le hostname,
#                  utilisée par Prisma pour les migrations
# Avec Postgres local : les deux pointent vers la même URL.
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# --- NextAuth (Auth.js v5) ---------------------------------------------------
AUTH_SECRET="change-me-générer-avec-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth providers (activer V2)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""

# --- Email transactionnel (Resend) -------------------------------------------
# Auth.js v5 Resend provider lit AUTH_RESEND_KEY automatiquement
AUTH_RESEND_KEY=""
# Utilisé hors Auth.js (emails transac custom : confirmation, facture…)
RESEND_API_KEY=""
EMAIL_FROM="The Court <noreply@thecourt.fr>"

# --- SMS (Twilio ou OVH SMS) — V2 --------------------------------------------
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM=""

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Stockage objet (Scaleway S3) --------------------------------------------
S3_ENDPOINT="https://s3.fr-par.scw.cloud"
S3_REGION="fr-par"
S3_BUCKET="padel-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Monitoring --------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="The Court"
